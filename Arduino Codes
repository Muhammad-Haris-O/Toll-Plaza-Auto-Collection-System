#include <SPI.h>
#include <MFRC522.h>
#include <Servo.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

#define RST_PIN 8
#define SS_PIN 10

#define sensorPin1 A2
#define sensorPin2 A3
#define buzzerPin 6

MFRC522 mfrc522(SS_PIN, RST_PIN);
Servo servo;

int card1Balance = 2000;
int card2Balance = 400;

int senVal1 = 0;
int senVal2 = 0;

int state = 0;
int servoPos = 0;

void setup() {

  Serial.begin(9600);

  lcd.init();
  lcd.backlight();

  pinMode(sensorPin1, INPUT);
  pinMode(sensorPin2, INPUT);
  pinMode(buzzerPin, OUTPUT);

  servo.attach(9);
  servo.write(90);

  SPI.begin();
  mfrc522.PCD_Init();

  lcd.setCursor(0, 0);
  lcd.print("Automatic Toll");
  lcd.setCursor(0, 1);
  lcd.print("System Ready");
  delay(3000);

  lcd.clear();
}

void loop() {

  senVal1 = digitalRead(sensorPin1);
  senVal2 = digitalRead(sensorPin2);

  lcd.setCursor(0, 0);
  lcd.print("Welcom To Kerala");

  if (senVal1 == 0) {

    servoDown();

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Vehicle Detected");

    delay(1500);

    lcd.clear();
    lcd.print("Scan Your Card");

    rfid();
  }

  if (senVal2 == 0 && state == 1) {

    servoUp();

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Have Safe Trip");

    delay(2000);

    state = 0;

    lcd.clear();
  }
}

void servoDown() {

  for (servoPos = 90; servoPos <= 180; servoPos++) {
    servo.write(servoPos);
    delay(5);
  }
}

void servoUp() {

  for (servoPos = 180; servoPos >= 90; servoPos--) {
    servo.write(servoPos);
    delay(5);
  }
}

void rfid() {

  while (true) {

    if (!mfrc522.PICC_IsNewCardPresent()) {
      delay(50);
      continue;
    }

    if (!mfrc522.PICC_ReadCardSerial()) {
      delay(50);
      continue;
    }

    String content = "";

    for (byte i = 0; i < mfrc522.uid.size; i++) {
      content.concat(String(mfrc522.uid.uidByte[i] < 0x10 ? " 0" : " "));
      content.concat(String(mfrc522.uid.uidByte[i], HEX));
    }

    content.toUpperCase();

    Serial.println(content);

    if (content.substring(1) == "1C 52 32 03") {

      if (card1Balance >= 500) {

        card1Balance -= 500;

        successMsg();

        lcd.setCursor(9, 1);
        lcd.print(card1Balance);

        state = 1;

        break;
      }

      else {

        lowBalance(card1Balance);
        state = 0;
        break;
      }

    }

    else if (content.substring(1) == "1C 52 32 03") {

      if (card2Balance >= 5000) {

        card2Balance -= 5000;

        successMsg();

        lcd.setCursor(9, 1);
        lcd.print(card2Balance);

        state = 1;

        break;

      }

      else {

        lowBalance(card2Balance);
        state = 0;
        break;
      }

    }

    else {

      digitalWrite(buzzerPin, HIGH);

      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Unknown Card");

      lcd.setCursor(0, 1);
      lcd.print("Access Denied");

      delay(800);

      digitalWrite(buzzerPin, LOW);

      lcd.clear();

      break;
    }
  }
}

void successMsg() {

  digitalWrite(buzzerPin, HIGH);
  delay(200);
  digitalWrite(buzzerPin, LOW);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Toll Paid");

  lcd.setCursor(0, 1);
  lcd.print("Balance:");

  delay(1000);
}

void lowBalance(int bal) {

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Low Balance");

  lcd.setCursor(0, 1);
  lcd.print("Bal:");
  lcd.print(bal);

  delay(2000);

  lcd.clear();
}
